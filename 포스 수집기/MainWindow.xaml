<Window x:Class="대진포스_쿼리.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:대진포스_쿼리"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Height="480" Width="600"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        ShowInTaskbar="False"
        Foreground="{DynamicResource ForegroundBrush}">
    <Window.Resources>
        <Style x:Key="PosActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단 컨트롤 영역 (제목 표시줄 제거 — 드래그/닫기만 제공) -->
            <Grid Grid.Row="0" Margin="10,8,10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 드래그 영역 + 액션 버튼 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleArea_MouseLeftButtonDown">
                    <Button x:Name="AutoLoginAndCollectButton"
                            Content="추출" Width="80" Height="32"
                            FontSize="13"
                            Background="{DynamicResource SuccessBrush}"
                            Foreground="White"
                            Margin="0,0,8,0"
                            Style="{StaticResource PosActionButton}"
                            Click="AutoLoginAndCollectButton_Click"/>
                    <Button x:Name="StopAutoCollectButton"
                            Content="⏹" Width="40" Height="32"
                            FontSize="14"
                            Background="{DynamicResource DangerBrush}"
                            Foreground="White"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            Style="{StaticResource PosActionButton}"
                            Click="StopAutoCollectButton_Click"/>
                    <Button x:Name="DbSettingsButton"
                            Content="⚙️ DB 설정" Width="100" Height="32"
                            FontSize="12"
                            Background="{DynamicResource StatusBarBackgroundBrush}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            Style="{StaticResource PosActionButton}"
                            Click="DbSettingsButton_Click"/>
                </StackPanel>

                <!-- 닫기 버튼 -->
                <Button Grid.Column="1" Content="✕"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TabTextNormalBrush}"
                        FontSize="13"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 진행 상태 표시 영역 -->
            <Grid Grid.Row="1" Margin="10,5,10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 전체 진행 상태 — 계정별 진행바와 중복되어 숨김. cs 참조 유지 위해 Visibility만 Collapsed. -->
                <StackPanel Grid.Row="0" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" Text="준비"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="ProgressText" Text="0%"/>
                    <TextBlock x:Name="DetailText" Text=""/>
                </StackPanel>

                <!-- 계정별 진행 패널 (두 열) -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
                            Background="{DynamicResource StatusBarBackgroundBrush}"
                            CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="🔵 junco" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock x:Name="Account1StatusText" Text="대기 중..." FontSize="11"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <ProgressBar x:Name="Account1ProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"
                                         Foreground="{DynamicResource StatusBarBorderBrush}"
                                         Background="{DynamicResource WindowBackgroundBrush}"/>
                            <TextBlock x:Name="Account1ProgressText" Text="0%" FontSize="11"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock x:Name="Account1DetailText" Text="" FontSize="10"
                                       Foreground="{DynamicResource TabTextNormalBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
                            Background="{DynamicResource StatusBarBackgroundBrush}"
                            CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="🟢 junco3" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock x:Name="Account2StatusText" Text="대기 중..." FontSize="11"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <ProgressBar x:Name="Account2ProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"
                                         Foreground="{DynamicResource StatusBarBorderBrush}"
                                         Background="{DynamicResource WindowBackgroundBrush}"/>
                            <TextBlock x:Name="Account2ProgressText" Text="0%" FontSize="11"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock x:Name="Account2DetailText" Text="" FontSize="10"
                                       Foreground="{DynamicResource TabTextNormalBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- WebView2 브라우저 영역 (백그라운드, 완전히 숨김) -->
            <Grid Grid.Row="2" Visibility="Collapsed">
                <wv2:WebView2 x:Name="WebView" Margin="10"/>
                <wv2:WebView2 x:Name="WebView2" Margin="10"/>
            </Grid>
        </Grid>
    </Border>
</Window>
