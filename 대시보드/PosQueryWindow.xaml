<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WpfApp2.PosQueryWindow"
        Title="취합 누락 목록" Height="420" Width="480"
        Icon="/대시보드아이콘 3.ico"
        Background="Transparent"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#2A2A3E" BorderThickness="1"
            Background="#0D0D12"
            CornerRadius="14">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border Background="#0D0D12" DockPanel.Dock="Top" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="40">
                    <TextBlock Text="취합 누락 목록 / 재추출" VerticalAlignment="Center" Margin="16,0,0,0"
                               FontWeight="Bold" FontSize="13" Foreground="#C0C0D8"/>
                    <Button Content="✕" Click="Close_Click"
                            Height="32" Width="40" HorizontalAlignment="Right" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#808098" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1E1E2E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 구분선 -->
            <Border DockPanel.Dock="Top" Height="1" Background="#1E1E2E"/>

            <!-- 콘텐츠 -->
            <Grid Margin="14,12,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 진행 상태 / 안내 텍스트 -->
                <TextBlock x:Name="HeaderText" Grid.Row="0"
                           Text="누락된 매장을 클릭하면 해당 매장만 취합합니다."
                           FontSize="11" Foreground="#606080" Margin="0,0,0,10"/>
                <TextBlock x:Name="RunningText" Grid.Row="0"
                           Text="매장현황 취합중..."
                           FontSize="12" Foreground="#FFB347"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- 날짜 재추출 박스 -->
                <Border Grid.Row="1" Background="#15151E" CornerRadius="8"
                        BorderBrush="#2A2A3E" BorderThickness="1"
                        Padding="12,10,12,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="날짜 재추출" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#C0C0D8"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border x:Name="RefetchDateButton" Grid.Column="1"
                                Width="130" Height="28"
                                Background="#25253A"
                                BorderBrush="#3A3A55" BorderThickness="1"
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                MouseLeftButtonUp="RefetchDateButton_MouseLeftButtonUp">
                            <TextBlock x:Name="RefetchDateText"
                                       Text="날짜 선택"
                                       FontSize="11"
                                       Foreground="#E0E0F0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="기존 데이터를 삭제하고 다시 수집합니다."
                                   FontSize="10" Foreground="#606080"
                                   VerticalAlignment="Center" Margin="10,0,10,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="RefetchBtn" Grid.Column="3"
                                Content="재추출" Width="68" Height="28" FontSize="11"
                                Foreground="#FFB347" Cursor="Hand"
                                Click="RefetchBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="#25253A"
                                            BorderBrush="#3A3A55" BorderThickness="1"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2E2E45"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- 누락 목록 -->
                <Border Grid.Row="2" Background="#13131B" CornerRadius="8" Padding="0">
                    <Border.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}">
                            <Setter Property="Opacity" Value="0.7"/>
                        </Style>
                    </Border.Resources>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="SkippedList" Margin="0"/>
                    </ScrollViewer>
                </Border>

                <!-- 빈 상태 텍스트 -->
                <TextBlock x:Name="EmptyText" Grid.Row="2"
                           Text="누락된 매장이 없습니다."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="#404060"
                           Visibility="Collapsed"/>

                <!-- 하단 버튼 영역 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <StackPanel.Resources>
                        <ControlTemplate x:Key="ListBtnTemplate" TargetType="Button">
                            <Border x:Name="bd" Background="#1E1E2E" BorderBrush="#2A2A3E"
                                    BorderThickness="1" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#252535"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </StackPanel.Resources>

                    <Button x:Name="DeleteSelectedBtn"
                            Content="선택 삭제" Width="78" Height="28" FontSize="11"
                            Margin="0,0,6,0"
                            Foreground="#FF8080" Cursor="Hand"
                            Click="DeleteSelectedBtn_Click"
                            Template="{StaticResource ListBtnTemplate}"/>

                    <Button x:Name="DeleteAllBtn"
                            Content="전체 삭제" Width="78" Height="28" FontSize="11"
                            Margin="0,0,6,0"
                            Foreground="#FF5050" Cursor="Hand"
                            Click="DeleteAllBtn_Click"
                            Template="{StaticResource ListBtnTemplate}"/>

                    <Button x:Name="RefreshBtn"
                            Content="새로고침" Width="80" Height="28" FontSize="11"
                            Foreground="#A0A0C0" Cursor="Hand"
                            Click="RefreshBtn_Click"
                            Template="{StaticResource ListBtnTemplate}"/>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
