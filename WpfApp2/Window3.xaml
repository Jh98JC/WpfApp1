<Window x:Name="Launcher" x:Class="WpfApp2.Window3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Window3" Height="30" Width="100"
        ResizeMode="NoResize" WindowStyle="None"
        Topmost="True" ShowInTaskbar="False"
        Background="Transparent" AllowsTransparency="True"
        UseLayoutRounding="True">

    <Border x:Name="Pill" CornerRadius="15" BorderThickness="1"
            MouseEnter="Pill_MouseEnter"
            MouseLeave="Pill_MouseLeave"
            MouseLeftButtonDown="MainGrid_MouseLeftButtonDown"
            MouseMove="MainGrid_MouseMove"
            MouseLeftButtonUp="MainGrid_MouseLeftButtonUp"
            MouseRightButtonDown="Grid_MouseRightButtonDown"
            Cursor="Hand">

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2E2E2E" Offset="0"/>
                <GradientStop Color="#141414" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush x:Name="PillBorder" Color="#484848"/>
        </Border.BorderBrush>

        <Grid>
            <!-- 상단 유리광 하이라이트 -->
            <Border CornerRadius="14,14,0,0" VerticalAlignment="Top" Height="12"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- G 아이콘 (arc ~300° + crossbar) -->
            <Viewbox Stretch="Uniform" Width="20" Height="20"
                     HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas Width="40" Height="40">
                    <Path x:Name="GPath"
                          StrokeThickness="3.5" Fill="Transparent"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M 28,7 A 15,15 0 1 0 35,20 L 22,20">
                        <Path.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E0E0E0" Offset="0"/>
                                <GradientStop Color="#909090" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Stroke>
                    </Path>
                </Canvas>
            </Viewbox>

            <!-- 하단 내부 그림자 -->
            <Border CornerRadius="0,0,14,14" VerticalAlignment="Bottom" Height="8"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#18000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Border>
</Window>
