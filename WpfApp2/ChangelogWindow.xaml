<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WpfApp2.ChangelogWindow"
        Title="업데이트 완료" Height="500" Width="700"
        Background="Transparent"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="CanResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border Background="{DynamicResource StatusBarBackgroundBrush}" DockPanel.Dock="Top" CornerRadius="16,16,0,0">
                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2" Background="{DynamicResource WindowBackgroundBrush}"
                            CornerRadius="16,16,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold" Text="업데이트 완료"
                               MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,6,0">
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click" Height="32" Width="40" Background="{DynamicResource WindowBackgroundBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 내용 영역 -->
            <Border BorderBrush="{DynamicResource WindowBackgroundBrush}" BorderThickness="1" CornerRadius="0,0,16,16">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <StackPanel Grid.Row="0" Margin="0,10,0,20">
                        <TextBlock Text="🎉 업데이트가 완료되었습니다!" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="VersionText" 
                                   Text="버전 1.0.1로 업데이트되었습니다" 
                                   FontSize="14" 
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- 구분선 -->
                    <Border Grid.Row="1" Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,0,0,20"/>

                    <!-- 변경 사항 -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="📝 변경 사항" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       Margin="0,0,0,15"/>

                            <TextBlock x:Name="ChangelogText" 
                                       TextWrapping="Wrap" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       LineHeight="24"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 버튼 영역 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                        <Button Content="변경 로그 보기" 
                                Width="130" 
                                Height="35" 
                                Margin="0,0,10,0"
                                Background="{DynamicResource ContextMenuBorderBrush}"
                                Foreground="{DynamicResource ForegroundBrush}"
                                FontWeight="SemiBold"
                                Click="ViewChangelog_Click"/>
                        <Button Content="확인" 
                                Width="130" 
                                Height="35" 
                                Background="#4CAF50"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
