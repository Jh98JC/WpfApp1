<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" x:Name="Setting"
        mc:Ignorable="av"
        x:Class="WpfApp2.SettingWindow"
        Title="셋팅창" Height="560" Width="600"
        Icon="/대시보드아이콘 3.ico"
        Background="Transparent"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="SettingWindow_PreviewKeyDown">

    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border Background="{DynamicResource WindowBackgroundBrush}" DockPanel.Dock="Top" CornerRadius="16,16,0,0">
                <Grid Height="40">
                    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="16,16,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <TextBlock Text="Setting" VerticalAlignment="Center" Margin="20,0,0,0"
                               FontWeight="Bold" FontSize="14"
                               MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click"
                            Height="32" Width="40" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                </Grid>
            </Border>

            <!-- 구분선 -->
            <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="16,0"/>

            <!-- 콘텐츠 영역 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                <StackPanel Margin="16,12,16,16">

                    <!-- 테마 섹션 -->
                    <TextBlock Text="테마" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="ThemePanel" Orientation="Horizontal" Margin="0,0,0,4"/>

                    <!-- 섹션 구분선 -->
                    <Border Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,16,0,16"/>

                    <!-- 아이콘 섹션 -->
                    <TextBlock Text="아이콘 표시" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,10"/>

                    <!-- 작업표시줄 체크박스 행 -->
                    <Border x:Name="TaskbarCard"
                            Background="{DynamicResource ContextMenuBorderBrush}"
                            BorderThickness="1.5" BorderBrush="Transparent"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,6" Cursor="Hand"
                            PreviewMouseLeftButtonDown="IconRow_MouseDown"
                            MouseLeftButtonUp="TaskbarRow_MouseLeftButtonUp"
                            MouseLeave="IconRow_MouseLeave">
                        <Grid IsHitTestVisible="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel IsHitTestVisible="False">
                                <TextBlock Text="작업표시줄 아이콘" FontSize="12"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="하단 작업표시줄에 앱 아이콘 표시"
                                           FontSize="10" Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowInTaskbarCheck" Grid.Column="1"
                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- 트레이 체크박스 행 -->
                    <Border x:Name="TrayCard"
                            Background="{DynamicResource ContextMenuBorderBrush}"
                            BorderThickness="1.5" BorderBrush="Transparent"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,0" Cursor="Hand"
                            PreviewMouseLeftButtonDown="IconRow_MouseDown"
                            MouseLeftButtonUp="TrayRow_MouseLeftButtonUp"
                            MouseLeave="IconRow_MouseLeave">
                        <Grid IsHitTestVisible="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel IsHitTestVisible="False">
                                <TextBlock Text="숨겨진 아이콘 영역" FontSize="12"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="시스템 트레이(숨겨진 아이콘)에 앱 아이콘 표시"
                                           FontSize="10" Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowTrayIconCheck" Grid.Column="1"
                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- 섹션 구분선 -->
                    <Border Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,16,0,16"/>

                    <!-- 단축키 섹션 -->
                    <TextBlock Text="메인 창 단축키" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="앱이 숨겨져 있을 때 메인 창을 불러오는 단축키"
                               FontSize="10" Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,10"/>
                    <Grid Height="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="88"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource ContextMenuBorderBrush}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,0" Margin="0,0,8,0">
                            <TextBlock x:Name="HotkeyDisplayText" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
                        </Border>
                        <Button x:Name="CaptureBtn" Grid.Column="1" Content="키 캡처" FontSize="11"
                                Background="{DynamicResource ContextMenuBorderBrush}"
                                Foreground="{DynamicResource ForegroundBrush}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                Click="CaptureBtn_Click"/>
                    </Grid>
                    <TextBlock x:Name="HotkeyStatusText" Text=""
                               FontSize="11" Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,6,0,0"/>

                    <!-- 섹션 구분선 -->
                    <Border Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,16,0,16"/>

                    <!-- 탭 / 기타 섹션 -->
                    <TextBlock Text="탭 관리" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="addTab" Content="탭 추가" Width="88" Height="28" FontSize="12"
                                Background="{DynamicResource ContextMenuBorderBrush}"
                                Foreground="{DynamicResource ForegroundBrush}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                Click="addTab_Click"/>
                        <Button x:Name="dbConfigBtn" Content="DB 연결 설정" Width="110" Height="28" FontSize="11"
                                Margin="8,0,0,0"
                                Background="{DynamicResource ContextMenuBorderBrush}"
                                Foreground="{DynamicResource ForegroundBrush}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                Visibility="Collapsed"
                                Click="dbConfigBtn_Click"/>
                    </StackPanel>

                    <!-- 섹션 구분선 -->
                    <Border Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,16,0,16"/>

                    <!-- 계정 / 버전 섹션 -->
                    <TextBlock Text="계정" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="versionText" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="logoutBtn" Content="로그아웃" Width="88" Height="28" FontSize="12"
                                    Background="{DynamicResource ContextMenuBorderBrush}"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                    Click="logoutBtn_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- 섹션 구분선 -->
                    <Border Height="1" Background="{DynamicResource StatusBarBorderBrush}" Margin="0,16,0,16"/>

                    <!-- 대진포스 쿼리 섹션 (테마 색상 반영) — 마스터 전용 -->
                    <Border x:Name="PosQueryCard"
                            Background="{DynamicResource ContextMenuBackgroundBrush}"
                            BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="14,12,14,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="대진포스 쿼리" FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PosLastRunText" Grid.Column="1"
                                           FontSize="10" Foreground="{DynamicResource TabTextNormalBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <StackPanel.Resources>
                                    <ControlTemplate x:Key="PosButtonTemplate" TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{DynamicResource ContextMenuBorderBrush}"
                                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ContextMenuItemHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </StackPanel.Resources>

                                <Button x:Name="posRunBtn" Content="수동 실행" Width="88" Height="28" FontSize="12"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        Template="{StaticResource PosButtonTemplate}"
                                        Click="posRunBtn_Click"/>

                                <Button x:Name="posSkippedBtn" Content="취합누락" Width="88" Height="28" FontSize="12"
                                        Foreground="#FFB347" Margin="8,0,0,0"
                                        Template="{StaticResource PosButtonTemplate}"
                                        Click="posSkippedBtn_Click"/>
                            </StackPanel>

                            <!-- 취합 로그 목록 -->
                            <Border Background="{DynamicResource StatusBarBackgroundBrush}"
                                    BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="8,6" MaxHeight="140">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="PosLogScroll_PreviewMouseWheel">
                                    <StackPanel x:Name="PosLogPanel"/>
                                </ScrollViewer>
                            </Border>

                            <TextBlock x:Name="PosLogEmpty" Text="취합 기록이 없습니다."
                                       FontSize="11" Foreground="{DynamicResource TabTextNormalBrush}"
                                       Margin="0,6,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
