<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" x:Name="Setting"
        mc:Ignorable="av"
        x:Class="WpfApp2.Window1"
        Title="Window1" Height="402" Width="600"
        Background="Transparent"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="Window1_PreviewKeyDown">
    <!-- 최상위 Border에 CornerRadius 적용 -->
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <!-- DockPanel 내부는 기존대로 -->
            <Border Background="{DynamicResource StatusBarBackgroundBrush}" DockPanel.Dock="Top" CornerRadius="16,16,0,0">
                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="4" Background="{DynamicResource WindowBackgroundBrush}"
                            CornerRadius="16,16,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold" Text="Setting"
                               MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,6,0">
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click" Height="32" Width="40"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border BorderBrush="{DynamicResource WindowBackgroundBrush}" BorderThickness="1" Width="598" CornerRadius="0,0,16,16">
                <Grid>
                    <Button x:Name="textsharp" Content="글꼴" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Background="{DynamicResource ContextMenuBorderBrush}" Width="71" Click="textsharp_Click"/>

                    <!-- 테마 섹션 -->
                    <TextBlock Text="테마" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="10,48,0,0" Foreground="{DynamicResource ForegroundBrush}"/>
                    <StackPanel x:Name="ThemePanel" Orientation="Horizontal"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="10,70,0,0"/>

                    <Button x:Name="addTab" Content="탭 추가" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,287,0,0" Background="{DynamicResource ContextMenuBorderBrush}" Width="93" Click="addTab_Click"/>
                    <TextBlock x:Name="versionText" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,330,0,0" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
                    <Button x:Name="clear" Content="버튼초기화" HorizontalAlignment="Left" Height="25" Margin="492,331,0,0" VerticalAlignment="Top" Width="94" FontSize="12" Background="#FFFF9A9A" BorderBrush="#FFFF9A9A" FontWeight="Bold" Click="clear_Click"/>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
