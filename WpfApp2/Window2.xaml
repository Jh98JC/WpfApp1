<Window x:Class="WpfApp2.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Window2" Height="600" Width="432"
        Background="#00000000" Foreground="#FFDCDCDC" WindowStyle="None" ResizeMode="CanResize"
        SnapsToDevicePixels="True" UseLayoutRounding="True" AllowsTransparency="True">
    <Window.Resources>
        <!-- 기존 리소스 유지 -->
        <SolidColorBrush x:Key="DarkWindowBrush" Color="#FF272727"/>
        <SolidColorBrush x:Key="DarkTabBrush" Color="#FF303030"/>
        <SolidColorBrush x:Key="DarkTabSelectedBrush" Color="#FF383838"/>
        <SolidColorBrush x:Key="DarkContentBrush" Color="#FF1E1E1E"/>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF272727"/>
            <Setter Property="BorderBrush" Value="#FF272727"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF333333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource DarkWindowBrush}"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel" Grid.Row="0" IsItemsHost="True" Background="{TemplateBinding Background}" Margin="6,0,30,0" />
                            <Border Grid.Row="1" Background="{StaticResource DarkContentBrush}" BorderBrush="#FF444444" BorderThickness="1" CornerRadius="6" Margin="1">
                                <ContentPresenter x:Name="PART_SelectedContentHost" Margin="1" ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Background" Value="{StaticResource DarkTabBrush}"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,-1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <DockPanel LastChildFill="False">
                                <!-- 닫기 버튼 (내용 오른쪽) -->
                                <Button x:Name="CloseBtn" Content="✕" Width="14" Height="14" Padding="0" Margin="4,0,2,0" DockPanel.Dock="Right"
                                        Background="{TemplateBinding Background}" BorderThickness="0" Foreground="#FFAAAAAA" Cursor="Hand" FontSize="10" ToolTip="탭 닫기" Click="TabCloseButton_Click"/>
                                <ContentPresenter Margin="2,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" ContentSource="Header"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DarkTabSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF666666"/>
                                <Setter Property="Panel.ZIndex" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter TargetName="CloseBtn" Property="Foreground" Value="#FFDDDDDD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A3A3A"/>
                                <Setter TargetName="CloseBtn" Property="Foreground" Value="#FFE0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <!-- 외곽 둥근 Border -->
    <Border CornerRadius="12" Background="#FF272727" BorderBrush="#FF444444" BorderThickness="1" SnapsToDevicePixels="True">
        <Grid Background="#00000000" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Title Bar: handle mouse down on the Grid to allow drag anywhere except on buttons -->
            <Border Grid.Row="0" Background="#FF272727" BorderThickness="0" CornerRadius="12,12,0,0">
                <Grid Margin="0,0,2,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Window2" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="Bold" Foreground="#FFCCCCCC" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="PhoneToggleButton" Content="📱" Width="32" Height="22" Style="{StaticResource TitleBarButtonStyle}" Click="PhoneToggle_Click" ToolTip="휴대폰 화면 토글"/>
                        <Button Content="─" Width="32" Height="22" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click"/>
                        <Button Content="☐" Width="32" Height="22" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeRestore_Click"/>
                        <Button Content="✕" Width="32" Height="22" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Address Bar -->
            <DockPanel x:Name="AddressBarPanel" Grid.Row="1" LastChildFill="True" Margin="8,4,8,4" Background="#FF272727" Height="22">
                <TextBlock Text="주소:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FFCCCCCC" DockPanel.Dock="Left" FontSize="12"/>
                <Button x:Name="GoButton" Content="이동" Width="50" Height="22" VerticalAlignment="Center" Click="GoButton_Click" Style="{StaticResource TitleBarButtonStyle}" DockPanel.Dock="Right" FontSize="12"/>
                <TextBox x:Name="AddressBox" Height="22" VerticalAlignment="Center" KeyDown="AddressBox_KeyDown" Margin="0,0,8,0" Foreground="#FFEFEFEF" Background="#FF333333" BorderBrush="#FF444444" FontSize="12"/>
            </DockPanel>
            <!-- Tabs -->
            <TabControl x:Name="Tabs" Grid.Row="2" Margin="1" Background="#FF272727">
                <TabItem Header="탭1">
                    <wv2:WebView2 x:Name="Browser" />
                </TabItem>
            </TabControl>
            <!-- Phone overlay: only WebView -->
            <Grid x:Name="PhoneHost" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed" Margin="8,4,8,4">
                <Border Background="#FF1E1E1E" CornerRadius="24" BorderBrush="#FF444444" BorderThickness="1" Padding="8" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="430" MinHeight="480">
                    <wv2:WebView2 x:Name="PhoneWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
