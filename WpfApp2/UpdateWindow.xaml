<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="av"
        x:Class="WpfApp2.UpdateWindow"
        Title="업데이트" Height="280" Width="420"
        Background="Transparent"
        Foreground="White"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">
    <Border BorderBrush="#3C3C3C" BorderThickness="1"
            Background="#2B2B2B"
            CornerRadius="12">
        <DockPanel>
            <!-- 메인 컨텐츠 -->
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 업데이트 아이콘 -->
                <Viewbox Grid.Row="0" Height="60" Width="60" 
                         HorizontalAlignment="Center" 
                         Margin="0,0,0,15">
                    <Canvas Width="24" Height="24">
                        <Path Data="M12,4V1L8,5L12,9V6C15.31,6 18,8.69 18,12C18,13.01 17.75,13.97 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12C20,7.58 16.42,4 12,4M12,18C8.69,18 6,15.31 6,12C6,10.99 6.25,10.03 6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12C4,16.42 7.58,20 12,20V23L16,19L12,15V18Z" 
                              Fill="White"/>
                    </Canvas>
                </Viewbox>

                <!-- 상태 메시지 -->
                <TextBlock x:Name="StatusText" 
                           Grid.Row="1" 
                           Text="업데이트를 확인하는 중..."
                           FontSize="16" 
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- 버전 정보 -->
                <StackPanel x:Name="VersionPanel" 
                            Grid.Row="2" 
                            Visibility="Collapsed"
                            Margin="0,0,0,15">
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="현재 버전: " FontWeight="SemiBold"/>
                        <Run x:Name="CurrentVersionText" Text="1.0.0"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center" Margin="0,5,0,0">
                        <Run Text="최신 버전: " FontWeight="SemiBold"/>
                        <Run x:Name="LatestVersionText" Text="1.0.0" Foreground="#4CAF50"/>
                    </TextBlock>
                </StackPanel>

                <!-- 업데이트 내용 -->
                <Border x:Name="ChangelogBorder" 
                        Grid.Row="3" 
                        BorderBrush="#3C3C3C" 
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Visibility="Collapsed"
                        Margin="0,0,0,15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ChangelogText" 
                                   TextWrapping="Wrap"
                                   Text="업데이트 내용이 여기에 표시됩니다."/>
                    </ScrollViewer>
                </Border>

                <!-- 진행 상태 -->
                <StackPanel x:Name="ProgressPanel" 
                            Grid.Row="4" 
                            Visibility="Collapsed"
                            Margin="0,0,0,15">
                    <ProgressBar x:Name="DownloadProgressBar" 
                                 Height="8" 
                                 Minimum="0" 
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#4CAF50"/>
                    <TextBlock x:Name="ProgressText" 
                               Text="0%" 
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"
                               FontSize="12"/>
                </StackPanel>

                <!-- 버튼들 -->
                <StackPanel Grid.Row="5" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center">
                    <Button x:Name="UpdateButton" 
                            Content="업데이트" 
                            Width="120" 
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="UpdateButton_Click"
                            Visibility="Collapsed">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="15,8">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45A049"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="CloseButton" 
                            Content="닫기" 
                            Width="120" 
                            Height="35"
                            Background="#3C3C3C"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="15,8"
                                                    BorderBrush="#3C3C3C"
                                                    BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
