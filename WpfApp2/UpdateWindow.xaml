<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="av"
        x:Class="WpfApp2.UpdateWindow"
        Title="업데이트" Height="450" Width="550"
        Background="Transparent"
        Foreground="White"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="#FF3F3F46" BorderThickness="1"
            Background="#FF1E1E1E"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="2" 
                            BlurRadius="15" 
                            Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="#FF2D2D30" 
                    CornerRadius="10,10,0,0"
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <materialDesign:PackIcon Grid.Column="0"
                                            Kind="Download"
                                            Width="32"
                                            Height="32"
                                            Foreground="#FF4CAF50"
                                            VerticalAlignment="Center"
                                            Margin="0,0,15,0"/>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                  Text="새 버전 업데이트" 
                                  FontSize="18" 
                                  FontWeight="Bold"
                                  Foreground="White"/>
                        <TextBlock x:Name="VersionInfoText"
                                  Text="업데이트 확인 중..."
                                  FontSize="12"
                                  Foreground="#FFAAAAAA"
                                  Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Grid.Column="2"
                            x:Name="HeaderCloseButton"
                            Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Close"
                                                Width="20"
                                                Height="20"
                                                Foreground="#FFAAAAAA"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto"
                         Padding="20"
                         Margin="0,10,0,10">
                <StackPanel>
                    <!-- Version Info Panel -->
                    <Border x:Name="VersionPanel"
                            Background="#FF252526"
                            CornerRadius="5"
                            Padding="15"
                            Margin="0,0,0,15"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="CheckCircle"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="#FF2196F3"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock Text="현재 버전: " 
                                          FontWeight="SemiBold"
                                          Foreground="White"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="CurrentVersionText" 
                                          Text="v1.1.3"
                                          Foreground="#FFAAAAAA"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="NewBox"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="#FF4CAF50"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock Text="최신 버전: " 
                                          FontWeight="SemiBold"
                                          Foreground="White"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="LatestVersionText" 
                                          Text="v1.1.4"
                                          Foreground="#FF4CAF50"
                                          FontWeight="Bold"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Release Notes -->
                    <TextBlock Text="릴리즈 노트:"
                              FontSize="14"
                              FontWeight="SemiBold"
                              Foreground="White"
                              Margin="0,0,0,10"/>

                    <Border x:Name="ChangelogBorder"
                            Background="#FF252526"
                            CornerRadius="5"
                            BorderBrush="#FF3F3F46"
                            BorderThickness="1"
                            MinHeight="150"
                            MaxHeight="200"
                            Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                     Padding="15">
                            <TextBlock x:Name="ChangelogText"
                                      Text="변경 내용을 불러오는 중..."
                                      TextWrapping="Wrap"
                                      Foreground="#FFCCCCCC"
                                      LineHeight="20"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Progress Panel -->
                    <StackPanel x:Name="ProgressPanel" 
                               Visibility="Collapsed"
                               Margin="0,15,0,0">
                        <TextBlock x:Name="ProgressText"
                                  Text="다운로드 중... 0%"
                                  Foreground="#FFAAAAAA"
                                  FontSize="12"
                                  Margin="0,0,0,8"/>
                        <ProgressBar x:Name="DownloadProgressBar"
                                    Height="6"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="0"
                                    Background="#FF3F3F46"
                                    Foreground="#FF4CAF50"
                                    BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" 
                    Background="#FF2D2D30"
                    CornerRadius="0,0,10,10"
                    Padding="20,15">
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Right">
                    <!-- Close/Skip Button -->
                    <Button x:Name="CloseButton"
                            Content="나중에"
                            Click="CloseButton_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Width="100"
                            Height="36"
                            Margin="0,0,10,0"
                            Foreground="#FFAAAAAA"/>

                    <!-- Update Button -->
                    <Button x:Name="UpdateButton"
                            Content="업데이트"
                            Click="UpdateButton_Click"
                            Width="120"
                            Height="36"
                            Visibility="Collapsed"
                            Foreground="White"
                            FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#FF4CAF50"/>
                                <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF45A049"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
