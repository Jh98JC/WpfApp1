<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="WpfApp2.DbConfigWindow"
    Title="DB 연결 설정" Width="480"
    SizeToContent="Height"
    Background="Transparent"
    WindowStyle="None" AllowsTransparency="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <Border DockPanel.Dock="Top" CornerRadius="16,16,0,0"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="40">
                    <TextBlock Text="Azure SQL 연결 설정" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center" Margin="20,0,0,0"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}"
                                Click="Close_Click" Width="32" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Margin="24,16,24,24">
                <TextBlock Text="Azure SQL 연결 문자열" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="ConnectionStringBox"
                         Height="80" AcceptsReturn="False" TextWrapping="Wrap"
                         FontSize="12" FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="8,6" Margin="0,0,0,6"
                         Style="{x:Null}"/>
                <TextBlock Text="예: Server=tcp:서버.database.windows.net,1433;Database=DB명;User Id=아이디;Password=비밀번호;Encrypt=True;"
                           FontSize="11" Foreground="{DynamicResource TabTextNormalBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <Button x:Name="TestBtn" Content="연결 테스트" Height="36" FontSize="13"
                        Background="{DynamicResource ContextMenuBorderBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="{DynamicResource StatusBarBorderBrush}"
                        Margin="0,0,0,6" Click="TestBtn_Click"/>
                <TextBlock x:Name="TestStatusText" Text="" FontSize="13" TextAlignment="Center"
                           Margin="0,0,0,16" TextWrapping="Wrap"/>

                <Separator Background="{DynamicResource StatusBarBorderBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="초기 마스터 계정 생성" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="DB에 계정이 없을 때만 적용됩니다."
                           FontSize="11" Foreground="{DynamicResource TabTextNormalBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="이름 (표시명)" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="MasterDisplayNameBox" Height="36" FontSize="13"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,10"
                         Style="{x:Null}"/>

                <TextBlock Text="마스터 아이디" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="MasterUsernameBox" Height="36" FontSize="13"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,10"
                         Style="{x:Null}"/>

                <TextBlock Text="마스터 비밀번호" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="MasterPasswordBox" Height="36" FontSize="13"
                             Background="{DynamicResource ContextMenuBorderBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource StatusBarBorderBrush}"
                             Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,16"/>

                <Button x:Name="SaveBtn" Content="저장 및 적용" Height="40" FontSize="13" FontWeight="Bold"
                        Background="{DynamicResource StatusBarBackgroundBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource StatusBarBackgroundBrush}"
                        Click="SaveBtn_Click"/>
                <Button x:Name="ConfirmBtn" Content="확인 (로그인 화면으로)" Height="40" FontSize="13" FontWeight="Bold"
                        Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                        Visibility="Collapsed" Margin="0,6,0,0"
                        Click="ConfirmBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Separator Background="{DynamicResource StatusBarBorderBrush}" Margin="0,20,0,16"/>

                <TextBlock Text="데이터 DB 연결 설정" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="차트에서 사용하는 매출 데이터 DB의 Azure SQL 연결 문자열입니다."
                           FontSize="11" Foreground="{DynamicResource TabTextNormalBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBox x:Name="DataConnectionStringBox"
                         Height="80" AcceptsReturn="False" TextWrapping="Wrap"
                         FontSize="12" FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="8,6" Margin="0,0,0,6"
                         Style="{x:Null}"/>

                <Button x:Name="DataTestBtn" Content="데이터 DB 연결 테스트" Height="36" FontSize="13"
                        Background="{DynamicResource ContextMenuBorderBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="{DynamicResource StatusBarBorderBrush}"
                        Margin="0,0,0,6" Click="DataTestBtn_Click"/>
                <TextBlock x:Name="DataTestStatusText" Text="" FontSize="13" TextAlignment="Center"
                           Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Button x:Name="DataSaveBtn" Content="데이터 DB 저장" Height="40" FontSize="13" FontWeight="Bold"
                        Background="{DynamicResource StatusBarBackgroundBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource StatusBarBackgroundBrush}"
                        Click="DataSaveBtn_Click"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
