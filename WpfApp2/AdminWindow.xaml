<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WpfApp2"
    x:Class="WpfApp2.AdminWindow"
    Title="관리자 패널" Height="600" Width="680"
    Background="Transparent"
    WindowStyle="None" AllowsTransparency="True"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:NotMasterConverter x:Key="NotMasterConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
        <local:ProcessedStatusColorConverter x:Key="StatusColor"/>
    </Window.Resources>
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <!-- Title Bar -->
            <Border DockPanel.Dock="Top" CornerRadius="16,16,0,0"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="40">
                    <TextBlock Text="관리자 패널" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center" Margin="20,0,0,0"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button Content="─" Style="{StaticResource TitleBarButtonStyle}"
                                Click="Minimize_Click" Width="36" Height="32"/>
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}"
                                Click="Close_Click" Width="36" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab Control -->
            <TabControl x:Name="AdminTabControl" Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource StatusBarBorderBrush}" Margin="10,8,10,10"
                        SelectionChanged="AdminTabControl_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{DynamicResource TabTextNormalBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource TabNormalBrush}"/>
                        <Setter Property="Padding" Value="16,8"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}"
                                            Margin="2,0,2,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabSelectedBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TabTextSelectedBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Tab 1: 계정 목록 -->
                <TabItem Header="계정 목록">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" MinHeight="36">
                            <Button x:Name="RefreshUsersBtn" Content="새로고침" Height="32" Width="100"
                                    FontSize="13" Background="{DynamicResource ContextMenuBorderBrush}"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                    Click="RefreshUsersBtn_Click"/>
                            <TextBlock x:Name="UserCountText" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="13" Margin="12,0,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="UsersGrid" Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  FontSize="13"
                                  Background="{DynamicResource ContextMenuBackgroundBrush}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                  RowBackground="{DynamicResource ContextMenuBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource ContextMenuBorderBrush}"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource StatusBarBorderBrush}"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource ContextMenuBorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="6,6"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" IsReadOnly="True"/>
                                <DataGridTextColumn Header="사용자명" Binding="{Binding Username}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="이름" Binding="{Binding DisplayName}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="역할" Binding="{Binding Role}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="가입일" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="관리" Width="*" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="삭제" Height="26" Padding="8,2"
                                                    FontSize="12" Foreground="White"
                                                    Background="#FF5A5A" BorderBrush="#FF5A5A"
                                                    Margin="2"
                                                    Click="DeleteUserBtn_Click"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding Role, Converter={StaticResource NotMasterConverter}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="UserStatusText" Grid.Row="2" Text="" FontSize="13"
                                   Foreground="#FF5A5A" Margin="0,6,0,0"/>
                    </Grid>
                </TabItem>

                <!-- Tab 2: 가입 신청 -->
                <TabItem Header="가입 신청">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" MinHeight="36">
                            <Button x:Name="RefreshPendingBtn" Content="새로고침" Height="32" Width="100"
                                    FontSize="13" Background="{DynamicResource ContextMenuBorderBrush}"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                    Click="RefreshPendingBtn_Click"/>
                            <TextBlock x:Name="PendingCountText" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="13" Margin="12,0,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="PendingGrid" Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  FontSize="13"
                                  Background="{DynamicResource ContextMenuBackgroundBrush}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                  RowBackground="{DynamicResource ContextMenuBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource ContextMenuBorderBrush}"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource StatusBarBorderBrush}"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionChanged="PendingGrid_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource ContextMenuBorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="6,6"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45" IsReadOnly="True"/>
                                <DataGridTextColumn Header="사용자명" Binding="{Binding Username}" Width="140" IsReadOnly="True"/>
                                <DataGridTextColumn Header="이름" Binding="{Binding DisplayName}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="신청일" Binding="{Binding RequestedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding ProcessedStatus, FallbackValue=대기중}"
                                                    Width="*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 선택된 행에 대한 액션 버튼 (DataGrid 외부) -->
                        <Border Grid.Row="2" Margin="0,8,0,0" Padding="10,8"
                                Background="{DynamicResource ContextMenuBorderBrush}"
                                BorderBrush="{DynamicResource StatusBarBorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Visibility="{Binding SelectedPendingUser, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NotNullToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SelectedUserText"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="13"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="ApproveSelectedBtn" Content="승인"
                                            Height="30" Width="70" FontSize="13"
                                            Foreground="White" Background="#4CAF50" BorderBrush="#4CAF50"
                                            Margin="0,0,8,0"
                                            Click="ApproveSelectedBtn_Click"/>
                                    <Button x:Name="RejectSelectedBtn" Content="거절"
                                            Height="30" Width="70" FontSize="13"
                                            Foreground="White" Background="#FF5A5A" BorderBrush="#FF5A5A"
                                            Click="RejectSelectedBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="PendingStatusText" Grid.Row="3" Text="" FontSize="13"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,6,0,0"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</Window>
