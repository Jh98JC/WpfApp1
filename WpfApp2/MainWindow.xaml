<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="av"
        x:Class="WpfApp2.MainWindow"
        Title="MainWindow" Height="683" Width="1100"
        Background="Transparent"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="CanResizeWithGrip" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <!-- Style used for dynamically created/restored buttons (independent of sample button) -->
        <Style x:Key="DynamicButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource ContextMenuBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ContextMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="MainBorder" CornerRadius="1.5"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.55" Color="#80000000"/>
                                </Border.Effect>
                            </Border>
                            <Canvas x:Name="RippleHost" IsHitTestVisible="False" ClipToBounds="True"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource StatusBarBorderBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border x:Name="RootBorder" BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <Border x:Name="상태창" CornerRadius="16,16,0,0" DockPanel.Dock="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="{DynamicResource WindowBackgroundBrush}">
                <Grid Height="32" Margin="0,0,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="setbtn"
                            Content="Setting"
                            Width="69" Height="24"
                            HorizontalAlignment="Right"
                            Margin="0,5,8,3"
                            Background="{DynamicResource StatusBarBackgroundBrush}"
                            FontWeight="Bold"
                            Foreground="White"
                            Click="setbtn_Click" BorderBrush="{DynamicResource StatusBarBackgroundBrush}" FontSize="12">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" Width="80" Margin="-3,0,0,0">
                        <Button Content="─" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click" Height="32" Width="40"/>
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click" Height="32" Width="40" Padding="1,1,1,1" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
            <DockPanel RenderTransformOrigin="0.5,0.5">
                <DockPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </DockPanel.RenderTransform>
                <Grid>
                    <TabControl x:Name="tabControl" TabStripPlacement="Left" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource WindowBackgroundBrush}" Margin="0,0,5,0">
                        <TabControl.Resources>
                            <Style TargetType="{x:Type TabControl}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabControl}">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="16">
                                                    <DockPanel>
                                                        <TabPanel x:Name="HeaderPanel"
                                                                  Panel.ZIndex="1"
                                                                  Margin="2,2,2,0"
                                                                  IsItemsHost="True"
                                                                  Background="Transparent"
                                                                  DockPanel.Dock="Left"/>
                                                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                                                          Margin="2"
                                                                          ContentSource="SelectedContent"/>
                                                    </DockPanel>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Foreground" Value="{DynamicResource TabTextNormalBrush}"/>
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Grid Width="120" Margin="3,2,3,2">
                                                <Border x:Name="MainBorder"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource TabNormalBrush}">
                                                    <ContentPresenter x:Name="ContentSite"
                                                                      Margin="12,0,8,0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"
                                                                      ContentSource="Header"
                                                                      RecognizesAccessKey="True"/>
                                                </Border>
                                                <Border x:Name="AccentBar"
                                                        Width="3"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="1.5"
                                                        Background="{DynamicResource TabAccentBrush}"
                                                        Opacity="0"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                                                    <Setter TargetName="AccentBar" Property="Opacity" Value="0.35"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TabTextHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource TabSelectedBrush}"/>
                                                    <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TabTextSelectedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="MainBorder" Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>
                        <TabItem x:Name="tabItem" Header="Main" Height="40" Background="{DynamicResource WindowBackgroundBrush}" Foreground="White" BorderBrush="{DynamicResource WindowBackgroundBrush}" IsSelected="True">
                            <TabItem.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="이름 수정" Click="RenameTabItem_Click"/>
                                    <MenuItem Header="탭 삭제" Click="DeleteTabItem_Click"/>
                                </ContextMenu>
                            </TabItem.ContextMenu>
                            <Border CornerRadius="16" Margin="0,0,0,3" ContextMenuOpening="DynamicButtonBorder_ContextMenuOpening" Background="{DynamicResource StatusBarBackgroundBrush}">
                                <Border.Resources>
                                    <Style TargetType="{x:Type Button}">
                                        <Style.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource StatusBarBorderBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Resources>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="버튼생성" Click="CreateButtonInBorder_Click"/>
                                        <MenuItem Header="차트생성" Click="CreateChartInBorder_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <Canvas x:Name="ButtonCanvas1" Width="3000" Height="2000"/>
                                </ScrollViewer>
                            </Border>
                        </TabItem>
                    </TabControl>
                    <Button x:Name="personalbtn" Content="OwnerOnly" HorizontalAlignment="Left" Height="40" VerticalAlignment="Bottom" Width="124" Padding="6,-1,6,2" Margin="2,0,0,5"
                            Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" FontWeight="Bold"
                            Click="personalbtn_Click">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource StatusBarBorderBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
