<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="WpfApp2.RegisterWindow"
    Title="회원가입 신청" Height="440" Width="360"
    Background="Transparent"
    WindowStyle="None" AllowsTransparency="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="16">
        <DockPanel>
            <Border DockPanel.Dock="Top" CornerRadius="16,16,0,0"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="40">
                    <TextBlock Text="회원가입 신청" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center" Margin="20,0,0,0"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}"
                                Click="Close_Click" Width="32" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Margin="28,16,28,24">
                <TextBlock Text="이름 (표시명)" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="DisplayNameBox" Height="38" FontSize="13"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,12"
                         Style="{x:Null}"/>

                <TextBlock Text="사용자명 (로그인 ID)" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Height="38" FontSize="13"
                         Background="{DynamicResource ContextMenuBorderBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource StatusBarBorderBrush}"
                         Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,12"
                         Style="{x:Null}"/>

                <Grid Margin="0,0,0,5">
                    <TextBlock Text="비밀번호" FontSize="13"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBlock x:Name="CapsLockIndicator"
                               Text="⇪ Caps Lock 켜짐" FontSize="11"
                               Foreground="#FF8C00" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
                <PasswordBox x:Name="PasswordBox" Height="38" FontSize="13"
                             Background="{DynamicResource ContextMenuBorderBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource StatusBarBorderBrush}"
                             Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,12"
                             GotKeyboardFocus="PasswordField_FocusChanged"
                             LostKeyboardFocus="PasswordField_FocusChanged"/>

                <TextBlock Text="비밀번호 확인" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="38" FontSize="13"
                             Background="{DynamicResource ContextMenuBorderBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource StatusBarBorderBrush}"
                             Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,20"
                             GotKeyboardFocus="PasswordField_FocusChanged"
                             LostKeyboardFocus="PasswordField_FocusChanged"/>

                <Button x:Name="SubmitBtn" Content="가입 신청" Height="42" FontSize="13" FontWeight="Bold"
                        Background="{DynamicResource StatusBarBackgroundBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource StatusBarBackgroundBrush}"
                        Margin="0,0,0,8" Click="SubmitBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock x:Name="StatusText" Text="" FontSize="13" TextAlignment="Center"
                           Foreground="#FF5A5A" TextWrapping="Wrap"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
