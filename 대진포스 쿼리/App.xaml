<Application x:Class="대진포스_쿼리.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:대진포스_쿼리"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 테마 브러시 — ThemeManager가 런타임에 부모 앱(WpfApp2)의 theme.txt를 읽어 교체한다. -->
            <SolidColorBrush x:Key="WindowBackgroundBrush"    Color="#F0F0F6"/>
            <SolidColorBrush x:Key="ForegroundBrush"          Color="#1A1A2A"/>
            <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#E4E4F0"/>
            <SolidColorBrush x:Key="StatusBarBorderBrush"     Color="#5575EE"/>
            <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#D8D8EA"/>

            <SolidColorBrush x:Key="ContextMenuBackgroundBrush"  Color="#F5F5FC"/>
            <SolidColorBrush x:Key="ContextMenuBorderBrush"      Color="#DCDCE8"/>
            <SolidColorBrush x:Key="ContextMenuForegroundBrush"  Color="#1A1A2A"/>
            <SolidColorBrush x:Key="ContextMenuItemHoverBrush"   Color="#E0E0F0"/>
            <SolidColorBrush x:Key="ContextMenuItemPressedBrush" Color="#D0D0E4"/>

            <SolidColorBrush x:Key="TabTextNormalBrush"   Color="#8080A0"/>
            <SolidColorBrush x:Key="TabTextHoverBrush"    Color="#404060"/>
            <SolidColorBrush x:Key="TabTextSelectedBrush" Color="#1A1A2A"/>

            <SolidColorBrush x:Key="AccentBrush"  Color="#E08020"/>
            <SolidColorBrush x:Key="DangerBrush"  Color="#D03030"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#208840"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
