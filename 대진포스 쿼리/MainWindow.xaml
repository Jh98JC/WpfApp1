<Window x:Class="대진포스_쿼리.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:대진포스_쿼리"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="대진포스 쿼리" Height="480" Width="860">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 컨트롤 영역 -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
            <!-- 버튼 영역 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Button x:Name="AutoLoginAndCollectButton" Content="🚀 날짜 설정 후 자동 수집" Width="180" Height="35" Click="AutoLoginAndCollectButton_Click" Margin="0,0,10,0" Background="LimeGreen" FontWeight="Bold" FontSize="13"/>
                <Button x:Name="LoginOnlyButton" Content="🔑 로그인만" Width="100" Height="35" Click="LoginOnlyButton_Click" Margin="0,0,10,0" Background="LightGreen"/>
                <Button x:Name="StopAutoCollectButton" Content="⏹ 중지" Width="80" Height="35" Click="StopAutoCollectButton_Click" Margin="0,0,10,0" IsEnabled="False" Background="IndianRed"/>
            </StackPanel>
        </StackPanel>

        <!-- 진행 상태 표시 영역 -->
        <Grid Grid.Row="1" Margin="10,5,10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 전체 진행 상태 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock x:Name="StatusText" Text="준비" FontSize="15" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <ProgressBar x:Name="ProgressBar" Height="18" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="ProgressText" Text="0%" FontSize="13" Margin="0,0,10,0"/>
                    <TextBlock x:Name="DetailText" Text="" FontSize="12" Foreground="Gray" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- 계정별 진행 패널 (세 열) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- junco 패널 -->
                <Border Grid.Column="0" BorderBrush="#4488CC" BorderThickness="1.5" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="🔵 junco" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#1155AA"/>
                        <TextBlock x:Name="Account1StatusText" Text="대기 중..." FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <ProgressBar x:Name="Account1ProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"/>
                        <TextBlock x:Name="Account1ProgressText" Text="0%" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="Account1DetailText" Text="" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- junco3 패널 -->
                <Border Grid.Column="2" BorderBrush="#44AA44" BorderThickness="1.5" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="🟢 junco3" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#116611"/>
                        <TextBlock x:Name="Account2StatusText" Text="대기 중..." FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <ProgressBar x:Name="Account2ProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"/>
                        <TextBlock x:Name="Account2ProgressText" Text="0%" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="Account2DetailText" Text="" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- junco4 패널 -->
                <Border Grid.Column="4" BorderBrush="#CC8800" BorderThickness="1.5" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="🟠 junco4" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#884400"/>
                        <TextBlock x:Name="Account3StatusText" Text="대기 중..." FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <ProgressBar x:Name="Account3ProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,3"/>
                        <TextBlock x:Name="Account3ProgressText" Text="0%" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="Account3DetailText" Text="" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- WebView2 브라우저 영역 (백그라운드, 완전히 숨김) -->
        <Grid Grid.Row="2" Visibility="Collapsed">
            <wv2:WebView2 x:Name="WebView" Margin="10"/>
            <wv2:WebView2 x:Name="WebView2" Margin="10"/>
            <wv2:WebView2 x:Name="WebView3" Margin="10"/>
        </Grid>

        <!-- 하단 데이터 표시 영역 제거 -->
    </Grid>
</Window>
